{
  "name": "@ball6847/git-commit-ai",
  "version": "0.2.0",
  "exports": "./src/cli.ts",
  "publish": {
    "include": ["src/**/*.ts", "README.md"]
  },
  "tasks": {
    "start": "deno run --allow-run --allow-env --allow-read --allow-write --allow-net src/cli.ts",
    "dev": "deno run --allow-run --allow-env --allow-read --allow-write --allow-net --watch src/cli.ts",
    "install:local": "deno install --global --allow-run --allow-env --allow-read --allow-write --allow-net -n git-commit-ai-local --config deno.json --force ./src/cli.ts",
    "test": "deno test --allow-run --allow-env --allow-read --allow-write --coverage=cov_profile --coverage-raw-data-only && deno coverage cov_profile --include='src/' --exclude='tests/' && deno coverage cov_profile --include='src/' --exclude='tests/' --html",
    "test:open": "xdg-open cov_profile/html/index.html 2>/dev/null || open cov_profile/html/index.html 2>/dev/null",
    "check": "deno check src/cli.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "publish:dry": "deno publish --dry-run"
  },
  "imports": {
    "@ai-sdk/anthropic": "npm:@ai-sdk/anthropic@^3.0.69",
    "@ai-sdk/cerebras": "npm:@ai-sdk/cerebras@^2.0.45",
    "@ai-sdk/openai": "npm:@ai-sdk/openai@^3.0.52",
    "@ai-sdk/mistral": "npm:@ai-sdk/mistral@^3.0.30",
    "@ai-sdk/openai-compatible": "npm:@ai-sdk/openai-compatible@^2.0.41",
    "@ai-sdk/provider": "npm:@ai-sdk/provider@^3.0.8",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
    "@openrouter/ai-sdk-provider": "npm:@openrouter/ai-sdk-provider@^2.5.1",
    "@std/fmt/colors": "jsr:@std/fmt@^1.0.9/colors",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@std/path": "jsr:@std/path@^1.0.7",
    "ai": "npm:ai@^6.0.158",
    "@std/assert": "jsr:@std/assert@^0.224.0",
    "ts-mockito": "npm:ts-mockito@^2.6.1",
    "typescript-result": "npm:typescript-result@^3.5.2"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": ["deno.ns", "dom", "es2022"],
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true,
    "proseWrap": "preserve"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
